# HonorBox fulfillment workflow: TEMPLATE.
#
# Run this in a PRIVATE repo (your "ops" repo), not in your public storefront
# repo: it holds your Stripe secret key and your fulfillment state.
#
# Setup (see docs/setup.md for the full walkthrough):
#   1. Create a private ops repo and copy this file to .github/workflows/fulfill.yml
#   2. Vendor scripts/fulfill.js, scripts/renew-invites.js + scripts/lib/ and
#      your store.config.json into it
#   3. Add secrets: STRIPE_SECRET_KEY (a restricted key is strongly recommended:
#      only "Checkout Sessions: Read"), GH_FULFILL_TOKEN (a fine-grained PAT with
#      admin on your private product repo(s) for collaborator invites)
#   4. Optionally set PUBLIC_STORE_REPO to publish the anonymized ledger to your
#      storefront's trust page.

name: Fulfill orders

on:
  schedule:
    # Every 30 minutes. This cadence is chosen by the free tier, not by taste.
    #
    # GitHub bills PRIVATE-repo Actions per job, rounded UP to a whole minute,
    # against 2,000 free minutes/month on the Free plan. This job runs ~15
    # seconds and is therefore billed as 1 minute, every time it fires. So the
    # monthly cost of a poll is just its run count:
    #
    #   */30 -> 2/h * 24 * 31 = 1,488 min/month   fits (512 min spare)
    #   */20 -> 3/h * 24 * 31 = 2,232 min/month   OVER by 232
    #   */15 -> 4/h * 24 * 31 = 2,976 min/month   OVER by 976 (~$5.86/month)
    #
    # The spare 512 minutes cover sale-triggered runs (fulfill-on-sale.yml,
    # 1 minute per sale) and manual dispatches. Tightening this cron is the
    # one edit here that can put a seller over the free tier. Read
    # docs/setup.md ("What this costs") before you change it.
    - cron: "*/30 * * * *"
  workflow_dispatch:

permissions:
  contents: write

concurrency:
  group: fulfill
  cancel-in-progress: false

jobs:
  fulfill:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@3d3c42e5aac5ba805825da76410c181273ba90b1 # v7.0.1
      - uses: actions/setup-node@820762786026740c76f36085b0efc47a31fe5020 # v7.0.0
        with:
          node-version: 22
      - name: Poll Stripe and fulfill
        env:
          STRIPE_SECRET_KEY: ${{ secrets.STRIPE_SECRET_KEY }}
          GH_FULFILL_TOKEN: ${{ secrets.GH_FULFILL_TOKEN }}
        run: |
          node scripts/fulfill.js \
            --config store.config.json \
            --state state/fulfill-state.json \
            --ledger ledger/ledger.json
      # GitHub expires an unaccepted invitation after seven days, and a buyer
      # who never opened the email looks exactly like a delivered sale until it
      # does. This re-issues before the clock runs out. It rides this job on
      # purpose: a private-repo job is billed rounded UP to a whole minute, so a
      # step inside a run you are already paying for is free, while a second
      # cron would cost a minute every time it fired. See docs/setup.md § 6.
      #
      # No Stripe key: renewal never looks at money.
      #
      # --state is the SHARED entitlement file. It is where a revocation gets
      # recorded, by `--revoke` when you refund somebody and by the subscription
      # reconciler when it enforces a lapse, and renewal refuses to re-invite
      # anyone on that list. One file, one answer.
      #
      # It runs only when the poll above succeeded, and that is deliberate. The
      # commit step below is what makes the renewal state durable, so a step
      # that ran after a failed poll would send emails whose record is then
      # thrown away. Renewal has a 24-hour margin and ~48 scheduled attempts
      # inside it; skipping the odd one costs nothing.
      - name: Renew invitations before GitHub expires them
        env:
          GH_FULFILL_TOKEN: ${{ secrets.GH_FULFILL_TOKEN }}
        run: |
          node scripts/renew-invites.js \
            --config store.config.json \
            --state state/bots-state.json
      - name: Commit state and ledger
        run: |
          git config user.name "honorbox-bot"
          git config user.email "actions@users.noreply.github.com"
          git add state/ ledger/
          git diff --cached --quiet || git commit -m "fulfill: $(date -u +%FT%TZ)"
          git push
      - name: Publish ledger to storefront
        if: ${{ vars.PUBLIC_STORE_REPO != '' }}
        env:
          GH_FULFILL_TOKEN: ${{ secrets.GH_FULFILL_TOKEN }}
          PUBLIC_STORE_REPO: ${{ vars.PUBLIC_STORE_REPO }}
        run: |
          if [ -f state/HAD_ACTIVITY ]; then
            git clone --depth 1 "https://x-access-token:${GH_FULFILL_TOKEN}@github.com/${PUBLIC_STORE_REPO}.git" store
            mkdir -p store/ledger
            cp ledger/ledger.json store/ledger/ledger.json
            cd store
            git config user.name "honorbox-bot"
            git config user.email "actions@users.noreply.github.com"
            git add ledger/ledger.json
            git diff --cached --quiet || { git commit -m "ledger: update"; git push; }
          fi
